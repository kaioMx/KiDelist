<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="8dp"
    app:strokeColor="#7A7B7C"
    app:strokeWidth="0.5dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:animationCache="true"
        android:background="@color/kidelist_surface"
        android:padding="14dp">

        <TextView
            android:id="@+id/txtNomeTarefa"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Nome_Tarefa"
            android:textColor="#0E3B66"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/groupNota"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Grupo das notas 1..5 -->
        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/groupNota"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:selectionRequired="false"
            app:singleSelection="true">

            <!-- Dica: no código você marca o selecionado e troca cor -->

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn1"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:backgroundTint="#0E3B66"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp"
                android:text="1"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                app:cornerRadius="10dp"
                app:strokeWidth="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn2"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:backgroundTint="#0E3B66"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp"
                android:text="2"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                app:cornerRadius="10dp"
                app:strokeWidth="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn3"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:backgroundTint="#F4B400"

                android:gravity="center"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"


                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp"
                android:text="3"
                android:textColor="#0E3B66"
                android:textStyle="bold"

                app:cornerRadius="10dp" />


            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn4"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:backgroundTint="#0E3B66"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp"
                android:text="4"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                app:cornerRadius="10dp"
                app:strokeWidth="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn5"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:backgroundTint="#0E3B66"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp"
                android:text="5"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                app:cornerRadius="10dp"
                app:strokeWidth="0dp" />

        </com.google.android.material.button.MaterialButtonToggleGroup>

        <TextView
            android:id="@+id/txtPergunta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Como você avalia?"
            android:textColor="#8A8A8A"
            android:textSize="13sp"
            app:layout_constraintBottom_toTopOf="@id/rowImagem"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/txtNomeTarefa" />

        <!-- Linha: câmera + thumb + status -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/rowImagem"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="10dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/txtPergunta">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnCamera"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:backgroundTint="#2D9CDB"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:strokeWidth="0dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_menu_camera"
                    android:tint="#FFFFFF" />
            </com.google.android.material.card.MaterialCardView>

            <ImageView
                android:id="@+id/imgThumb"
                android:layout_width="110dp"
                android:layout_height="44dp"
                android:layout_marginStart="10dp"
                android:background="#EAEAEA"
                android:scaleType="centerCrop"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/btnCamera"
                app:layout_constraintTop_toTopOf="parent"
                tools:src="@android:drawable/ic_menu_gallery" />

            <TextView
                android:id="@+id/txtStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FEITO"
                android:textColor="#27AE60"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
