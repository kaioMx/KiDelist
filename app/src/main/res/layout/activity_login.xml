<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Barra azul do topo -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:background="#0A2F5F"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvTituloApp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ki Delist"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="20sp" />
    </LinearLayout>

    <!-- Card branco central -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardLogin"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="32dp"
        app:cardCornerRadius="16dp"
        app:cardUseCompatPadding="true"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Título Bem-vindo -->

            <!-- Subtítulo -->

            <TextView
                android:id="@+id/tvBemVindo"
                android:layout_width="295dp"
                android:layout_height="wrap_content"
                android:text="Bem-vindo(a)"
                android:textAlignment="center"
                android:textColor="#0959B3"
                android:textSize="22sp"
                android:gravity="center"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSubtitulo"
                android:layout_width="297dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Entre para acessar o check list da loja"
                android:textAlignment="center"
                android:textColor="#666666"
                android:textSize="14sp" />

            <!-- Campo usuário -->
            <EditText
                android:id="@+id/etUsuario"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_input_grey"
                android:hint="Usuário ou e-mail"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textSize="14sp"
                android:inputType="textEmailAddress" />

            <!-- Campo senha -->
            <EditText
                android:id="@+id/etSenha"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_input_grey"
                android:hint="Senha"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textSize="14sp"
                android:inputType="textPassword" />

            <!-- Botão Entrar -->
            <Button
                android:id="@+id/btnEntrar"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="24dp"
                android:text="Entrar"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@android:color/white"
                app:backgroundTint="@null"
                android:background="@drawable/bg_botao_amarelo" />
        </LinearLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
